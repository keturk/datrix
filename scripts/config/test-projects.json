{
  "description": "Shared project definitions for testing and generation",
  "defaultLanguage": "python",
  "defaultPlatform": "docker",
  "projects": {
    "foundation": [
      {"name": "foundation",            "path": "examples/01-foundation/system.dtrx",                                      "description": "Foundation examples and core syntax patterns"}
    ],
    "features": [
      {"name": "entities",              "path": "examples/02-features/01-core-data-modeling/entities/system.dtrx",              "description": "Basic entity definitions with fields and types"},
      {"name": "enums",                 "path": "examples/02-features/01-core-data-modeling/enums/system.dtrx",                 "description": "Enum types with values"},
      {"name": "rest-api",              "path": "examples/02-features/01-core-data-modeling/rest-api/system.dtrx",              "description": "REST API endpoints with CRUD and custom routes"},
      {"name": "computed-fields",       "path": "examples/02-features/01-core-data-modeling/computed-fields/system.dtrx",       "description": "Computed/derived fields"},
      {"name": "relationships",         "path": "examples/02-features/01-core-data-modeling/relationships/system.dtrx",         "description": "Entity relationships (belongsTo, hasMany)"},
      {"name": "validation",            "path": "examples/02-features/01-core-data-modeling/validation/system.dtrx",            "description": "Field validation rules"},
      {"name": "lifecycle-hooks",       "path": "examples/02-features/01-core-data-modeling/lifecycle-hooks/system.dtrx",       "description": "Lifecycle hooks (before/after create/update)"},
      {"name": "authentication",        "path": "examples/02-features/01-core-data-modeling/authentication/system.dtrx",        "description": "Authentication with Password type and roles"},
      {"name": "pubsub",               "path": "examples/02-features/02-service-architecture/pubsub/system.dtrx",               "description": "Event publishing and subscribing"},
      {"name": "multi-service",         "path": "examples/02-features/02-service-architecture/multi-service/system.dtrx",       "description": "Multiple services with discovery"},
      {"name": "modules-imports",       "path": "examples/02-features/02-service-architecture/modules-imports/system.dtrx",     "description": "Shared modules with imports"},
      {"name": "functions",             "path": "examples/02-features/02-service-architecture/functions/system.dtrx",            "description": "Entity, module, and API-level functions"},
      {"name": "resilience",            "path": "examples/02-features/02-service-architecture/resilience/system.dtrx",           "description": "Resilience patterns (retry, circuit breaker)"},
      {"name": "cache",                 "path": "examples/02-features/03-infrastructure-blocks/cache/system.dtrx",              "description": "Redis caching with hash, counter, TTL"},
      {"name": "cqrs",                  "path": "examples/02-features/03-infrastructure-blocks/cqrs/system.dtrx",               "description": "CQRS pattern with views, commands, queries"},
      {"name": "jobs",                  "path": "examples/02-features/03-infrastructure-blocks/jobs/system.dtrx",                "description": "Background jobs with scheduling"},
      {"name": "nosql",                 "path": "examples/02-features/03-infrastructure-blocks/nosql/system.dtrx",               "description": "NoSQL/document store collections"},
      {"name": "storage",              "path": "examples/02-features/03-infrastructure-blocks/storage/system.dtrx",              "description": "Object/blob storage folders"},
      {"name": "graphql",               "path": "examples/02-features/03-infrastructure-blocks/graphql/system.dtrx",            "description": "GraphQL API with types, queries, mutations"},
      {"name": "advanced-types",        "path": "examples/02-features/04-advanced-data-features/advanced-types/system.dtrx",    "description": "Advanced types (Money, Slug, semantic types)"},
      {"name": "advanced-relationships","path": "examples/02-features/04-advanced-data-features/advanced-relationships/system.dtrx", "description": "Many-to-many and hasOne relationships"},
      {"name": "transactions",          "path": "examples/02-features/04-advanced-data-features/transactions/system.dtrx",      "description": "Transaction blocks for atomic operations"},
      {"name": "advanced-cache",        "path": "examples/02-features/04-advanced-data-features/advanced-cache/system.dtrx",    "description": "Sorted sets, sets, lists, TTL, prefix"},
      {"name": "fulltext-search",       "path": "examples/02-features/04-advanced-data-features/fulltext-search/system.dtrx",   "description": "Full-text search indexes and queries"},
      {"name": "batch-operations",      "path": "examples/02-features/04-advanced-data-features/batch-operations/system.dtrx",  "description": "Batch operations and CQRS refreshOn"},
      {"name": "advanced-queries",      "path": "examples/02-features/04-advanced-data-features/advanced-queries/system.dtrx",  "description": "Advanced query patterns (whereIn, whereNull, orderBy)"},
      {"name": "webhooks",              "path": "examples/02-features/04-advanced-data-features/webhooks/system.dtrx",           "description": "Webhook endpoints and idempotency"},
      {"name": "field-security",        "path": "examples/02-features/04-advanced-data-features/field-security/system.dtrx",    "description": "Encrypted and sensitive field constraints"},
      {"name": "multi-database",        "path": "examples/02-features/05-infrastructure-combinations/multi-database/system.dtrx","description": "Multiple databases in one service"},
      {"name": "mixed-infrastructure",  "path": "examples/02-features/05-infrastructure-combinations/mixed-infrastructure/system.dtrx", "description": "RDBMS + cache + pubsub + jobs combined"},
      {"name": "dual-api",              "path": "examples/02-features/05-infrastructure-combinations/dual-api/system.dtrx",     "description": "REST + GraphQL APIs on the same service"},
      {"name": "advanced-flow-control", "path": "examples/02-features/06-advanced-language-features/advanced-flow-control/system.dtrx", "description": "Try/catch, match, null coalescing"},
      {"name": "external-integration",  "path": "examples/02-features/06-advanced-language-features/external-integration/system.dtrx", "description": "External service integration patterns"}
    ],
    "domains": [
      {"name": "blog-cms",            "path": "examples/03-domains/blog-cms/system.dtrx",             "description": "Blog CMS with content management"},
      {"name": "ecommerce",           "path": "examples/03-domains/ecommerce/system.dtrx",           "description": "E-commerce system with 5 services"},
      {"name": "finance",             "path": "examples/03-domains/finance/system.dtrx",              "description": "Finance with accounts, transactions, compliance"},
      {"name": "food-delivery",       "path": "examples/03-domains/food-delivery/system.dtrx",        "description": "Food delivery with restaurants, orders, drivers"},
      {"name": "healthcare",          "path": "examples/03-domains/healthcare/system.dtrx",           "description": "Healthcare system with HIPAA patterns"},
      {"name": "hr-platform",         "path": "examples/03-domains/hr-platform/system.dtrx",          "description": "HR with employees, payroll, recruitment"},
      {"name": "iot-platform",        "path": "examples/03-domains/iot-platform/system.dtrx",         "description": "IoT with devices, telemetry, firmware rollout"},
      {"name": "learning-management", "path": "examples/03-domains/learning-management/system.dtrx",  "description": "LMS with courses, enrollments, grading"},
      {"name": "logistics",           "path": "examples/03-domains/logistics/system.dtrx",            "description": "Logistics with shipments, fleet, routes"},
      {"name": "real-estate",         "path": "examples/03-domains/real-estate/system.dtrx",          "description": "Real estate listings, viewings, contracts"},
      {"name": "social-platform",     "path": "examples/03-domains/social-platform/system.dtrx",      "description": "Social platform with posts, follows, notifications"},
      {"name": "task-management",     "path": "examples/03-domains/task-management/system.dtrx",      "description": "Task management with projects and assignments"}
    ]
  },
  "testSets": {
    "quick": ["foundation", "entities", "ecommerce"],
    "default": ["foundation", "ecommerce", "social-platform", "finance"],
    "all": ["foundation", "entities", "enums", "rest-api", "computed-fields", "relationships", "validation", "lifecycle-hooks", "authentication", "pubsub", "multi-service", "modules-imports", "functions", "resilience", "cache", "cqrs", "jobs", "nosql", "storage", "graphql", "advanced-types", "advanced-relationships", "transactions", "advanced-cache", "fulltext-search", "batch-operations", "advanced-queries", "webhooks", "field-security", "multi-database", "mixed-infrastructure", "dual-api", "advanced-flow-control", "external-integration", "ecommerce", "healthcare", "blog-cms", "social-platform", "task-management", "learning-management", "real-estate", "logistics", "finance", "food-delivery", "iot-platform", "hr-platform"],
    "foundation": ["foundation"],
    "features": ["entities", "enums", "rest-api", "computed-fields", "relationships", "validation", "lifecycle-hooks", "authentication", "pubsub", "multi-service", "modules-imports", "functions", "resilience", "cache", "cqrs", "jobs", "nosql", "storage", "graphql", "advanced-types", "advanced-relationships", "transactions", "advanced-cache", "fulltext-search", "batch-operations", "advanced-queries", "webhooks", "field-security", "multi-database", "mixed-infrastructure", "dual-api", "advanced-flow-control", "external-integration"],
    "features-core": ["entities", "enums", "rest-api", "computed-fields", "relationships", "validation", "lifecycle-hooks", "authentication"],
    "features-service-arch": ["pubsub", "multi-service", "modules-imports", "functions", "resilience"],
    "features-infra": ["cache", "cqrs", "jobs", "nosql", "storage", "graphql"],
    "features-advanced": ["advanced-types", "advanced-relationships", "transactions", "advanced-cache", "fulltext-search", "batch-operations", "advanced-queries", "webhooks", "field-security"],
    "features-combos": ["multi-database", "mixed-infrastructure", "dual-api"],
    "features-language": ["advanced-flow-control", "external-integration"],
    "domains": ["blog-cms", "ecommerce", "finance", "food-delivery", "healthcare", "hr-platform", "iot-platform", "learning-management", "logistics", "real-estate", "social-platform", "task-management"],
    "typescript-validation": ["entities", "rest-api", "relationships", "pubsub", "cache", "cqrs", "jobs", "blog-cms"]
  }

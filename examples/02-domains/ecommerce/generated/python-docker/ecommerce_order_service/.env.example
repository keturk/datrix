# ecommerce.OrderService Environment Configuration
# Copy this file to .env and fill in the values.
# Auto-generated by datrix-codegen-python.

# Application
APP_NAME=ecommerce.OrderService
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8002

# Database (postgresql)
DB_DATABASE_URL=postgresql+asyncpg://localhost:5432/ecommerce_orders
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Message Broker
KAFKA_BROKERS=localhost:9092

# ecommerce.ProductService service (required)
ECOMMERCE_PRODUCT_SERVICE_SERVICE_URL=
# ecommerce.PaymentService service (required)
ECOMMERCE_PAYMENT_SERVICE_SERVICE_URL=
# ecommerce.ShippingService service (required)
ECOMMERCE_SHIPPING_SERVICE_SERVICE_URL=

# Metrics
METRICS_ENDPOINT=/metrics

# JWT Authentication
JWT_SECRET=dev-secret-change-in-production

# Secrets Management
SECRETS_BACKEND=environment

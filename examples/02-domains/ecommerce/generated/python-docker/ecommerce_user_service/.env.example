# Application
PORT=3000

# Secrets (getSecret() / SecretsService)
SECRETS_BACKEND=environment
JWT_SECRET=
DATABASE_URL=postgresql://localhost:5432/app

# Optional: HashiCorp Vault (when SECRETS_BACKEND=vault)
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=
# VAULT_NAMESPACE=

# Optional: AWS Secrets Manager (when SECRETS_BACKEND=aws)
# AWS_REGION=us-east-1
# AWS_SECRET_PREFIX=

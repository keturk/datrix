# ecommerce.UserService Environment Configuration
# Copy this file to .env and fill in the values.
# Auto-generated by datrix-codegen-python.

# Application
APP_NAME=ecommerce.UserService
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database (postgresql)
DB_DATABASE_URL=postgresql+asyncpg://localhost:5432/ecommerce_users
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Message Broker
KAFKA_BROKERS=localhost:9092


# Metrics
METRICS_ENDPOINT=/metrics

# JWT Authentication
JWT_SECRET=dev-secret-change-in-production

# Secrets Management
SECRETS_BACKEND=environment

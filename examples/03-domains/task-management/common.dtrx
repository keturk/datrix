
// Shared module - defines reusable types across all task management services
// BaseEntity, MAX_PAGE_SIZE, and DEFAULT_PAGE_SIZE are provided by the Datrix standard library.
module taskapp.common {

    // Priority levels shared across services
    enum Priority {
        Low : value('low'),
        Medium : value('medium'),
        High : value('high'),
        Critical : value('critical')
    }

    const MAX_TITLE_LENGTH = 200;
    const MAX_DESCRIPTION_LENGTH = 10000;
}

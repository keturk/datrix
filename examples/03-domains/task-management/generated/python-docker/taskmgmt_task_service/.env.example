# taskmgmt.TaskService Environment Configuration
# Copy this file to .env and fill in the values.
# Auto-generated by datrix-codegen-python.

# Application
APP_NAME=taskmgmt.TaskService
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8012

# Database (postgresql)
DB_DATABASE_URL=postgresql+asyncpg://localhost:5432/task_tasks
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20



# taskmgmt.ProjectService service (required)
TASKMGMT_PROJECT_SERVICE_SERVICE_URL=
# taskmgmt.UserService service (required)
TASKMGMT_USER_SERVICE_SERVICE_URL=

# Metrics
METRICS_ENDPOINT=/metrics

# JWT Authentication
JWT_SECRET=dev-secret-change-in-production

# Secrets Management
SECRETS_BACKEND=environment


// shared-data-exchange.dtrx
// Shared object storage landing zone (demonstrates `storage` in a shared block).
shared DataExchange {
    storage landing('config/shared-block/shared-exchange-storage.yaml') {
        folder raw_data : path('raw/{tenantId}'), maxSize('100mb');
        folder processed_data : path('processed/{tenantId}'), maxSize('100mb');
    }
}

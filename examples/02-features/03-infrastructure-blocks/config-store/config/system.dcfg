config system shop.System {
  base {
    language = "python";
    deployment {
      runtime = "docker-compose";
      provider = "local";
    }
    defaultTimeout = 30000;
    maxPageSize = 100;
    env {
      DEBUG = false;
      CORS_ORIGINS = "[\"*\"]";
      SECRETS_BACKEND = "environment";
    }
    secrets {
      provider = "env";
    }
    gateway {
      port = 80;
      rateLimit {
        default {
          requests = 100;
          window = "1m";
          key = "ip";
        }
      }
      auth {
        jwt {
          algorithm = "RS256";
          issuer = "shop";
          expiresIn = 86400;
        }
      }
      cors {
        origins = ["http://localhost:3000"];
        methods = ["GET", "POST", "PUT", "DELETE", "PATCH"];
        headers = ["Content-Type", "Authorization"];
      }
    }
    observability {
      metrics {
        provider = "prometheus";
        endpoint = "/metrics";
        includeDefault = true;
      }
      tracing {
        provider = "jaeger";
        samplingRate = 0.1;
      }
      logging {
        level = "info";
        format = "json";
        provider = "loki";
      }
      visualization {
        provider = "grafana";
      }
      alerting {
        provider = "alertmanager";
      }
    }
    serviceDiscovery {
      type = "consul";
      host = "localhost";
      port = 8500;
      datacenter = "dc1";
    }

    // Runtime config store. Authors write 'flavor' (mapped to the canonical
    // 'platform' at the emitter boundary); the local Consul container profile
    // needs no cloud credentials. Present here so generation emits the runtime
    // client, the remote_defaults.json artifact, and the Docker config-store
    // service. featureFlag profiles allow Boolean-only keys; freeform profiles
    // allow any scalar type with optional constraints.
    configStore {
      engine = "consul";
      flavor = "container";
      applicationName = "shop-catalog";
      environment = "dev";
      pollingIntervalSeconds = 30;
      failOpen = true;

      profiles {
        featureFlags {
          kind = "featureFlag";
          keys {
            enableNewCheckout {
              type = "Boolean";
              default = false;
              description = "Enable the new checkout flow for all shoppers.";
            }
          }
        }

        rateLimits {
          kind = "freeform";
          keys {
            apiRequestsPerMinute {
              type = "Integer";
              default = 1000;
              description = "Max catalog API requests per shopper per minute.";
              constraints {
                min = 1;
                max = 10000;
              }
            }
          }
        }
      }
    }
  }

  profile test as "test" extends base {
    alias env = "TEST";
    alias resource = "test";
  }

  profile development as "dev" extends base {
    alias env = "DEV";
    alias resource = "dev";
  }
}

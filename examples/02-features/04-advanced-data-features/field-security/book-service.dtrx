        #catalog.Book book = catalog.Book.create({
            title: "Clean Code",
            isbn: "9780132350884",
            author: "Robert Martin",
            publicationYear: 2008,
            categoryId: cat.id,
            branchId: br.id,
            price: 24.99,
            metadata: {},
            tags: []
        });
        book.save();
        assert book.isAvailable == true;
    }

    test("computed isOldBook is true for pre-2000 books") {
        #catalog.Category cat = catalog.Category.create({ name: "SpecCatOldBook" });

        br.save();
        #catalog.Book book = catalog.Book.create({
            title: "Test Driven Development",
            isbn: "9780321146533",
            author: "Kent Beck",
            publicationYear: 2002,
            categoryId: cat.id,
            branchId: br.id,
            price: 29.99,
            metadata: {},
            tags: []
        });
        book.save();
        book.status = BookStatus.CheckedOut;
        book.save();
        assert book.canRenew() == true;
    }


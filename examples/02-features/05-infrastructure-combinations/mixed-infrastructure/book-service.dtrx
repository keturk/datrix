
// Mixed infrastructure feature example - self-contained service demonstrating('config/service.yaml') :
// - rdbms block for relational entity storage
// - nosql block for document-oriented analytics data
// - cache block for fast in-memory lookups
// - storage block for file/blob storage
// All four infrastructure types coexist in a single service

// Define a service in the 'library' namespace with version and description
service library.BookService('config/book-service.yaml') : version('1.0.0'), description('Book management service') {

    // Service infrastructure configuration
    discovery { }                                              // Service discovery (auto-configured)

    // Enum for tracking book availability
    enum BookStatus {
        Available,
        CheckedOut,
        Reserved
    }

    // Relational database block - primary entity storage
    rdbms bookDb {

        // Abstract entities provide reusable field definitions; they don't generate tables
        abstract entity BaseEntity {
            UUID id : primaryKey, server = uuid();
            DateTime createdAt : server = now();
            DateTime updatedAt : server = now();
        }

        // Primary book data in relational storage
        entity Book extends BaseEntity {
            String(200) title;
            String(100) author;
            BookStatus status = BookStatus.Available;
        }
    }

    // NoSQL document database block - for schema-flexible analytics data
    nosql analytics {

        // 'collection' defines a document store for reading history
        collection ReadingHistory {
            UUID userId : index;
            UUID bookId : index;
            DateTime startedAt : server = now();
            Int pagesRead;
            // JSON type stores arbitrary structured data without a fixed schema
            JSON metadata;

            // Composite index for querying a user's reading history by time
            index(userId, startedAt);
        }
    }

    // Cache block - in-memory data store for fast reads
    cache redis {
        // 'hash' stores a key-value structure in Redis with TTL
        hash BookViewCache : prefix('bookview:'), ttl(300) {
            UUID bookId : key;
            Int viewCount;
            DateTime lastViewed : server;
        }
    }

    // Storage block - file/blob storage for media assets
    storage media {
        // 'folder' declares a storage location with path, MIME restrictions, and size limit
        folder covers : path('covers/'), allowed(['image/jpeg', 'image/png', 'image/webp']), maxSize('5mb')
    }
}

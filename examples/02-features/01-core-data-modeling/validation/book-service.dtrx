
// Validation feature example - self-contained service demonstrating('config/service.yaml') :
// - Field-level constraints: trim, min(), positive
// - Custom validate block with conditional logic
// - ValidationError for user-facing error messages

// Define a service in the 'library' namespace with version and description
service library.BookService('config/book-service.yaml') : version('1.0.0'), description('Book management service') {

    // Service infrastructure configuration
    discovery { }                                              // Service discovery (auto-configured)

    // Relational database block - groups entities (tables) under a named datasource
    rdbms bookDb {

        // Abstract entities provide reusable field definitions; they don't generate tables
        abstract entity BaseEntity {
            UUID id : primaryKey, server = uuid();
            DateTime createdAt : server = DateTime.now();
            DateTime updatedAt : server = DateTime.now();
        }

        // Entity with field-level and block-level validation
        entity Book extends BaseEntity {
            // 'trim' auto-trims whitespace on input
            String(200) title : trim;
            String(20) isbn;
            Int publicationYear;
            // 'min(1)' ensures the value is at least 1
            Int pageCount : min(1);
            // 'positive' ensures the value is greater than zero
            Decimal(5, 2) price : positive;

            // Custom validation block - runs before create and update operations
            validate {
                if (title.trim().isEmpty())
                    // ValidationError raises a validation error with a user-facing message
                    ValidationError("Title cannot be empty");
                if (publicationYear > DateTime.now().year())
                    ValidationError("Publication year cannot be in the future");
                if (publicationYear < 1450)
                    ValidationError("Publication year cannot be before printing press invention");
            }
        }
    }

    test("validation rejects empty title") {
        assert throws(
            () => bookDb.Book.create({
                title: "",
                isbn: "1234567890",
                publicationYear: 2020,
                pageCount: 100,
                price: 19.99
            }),
            ValidationError("Title cannot be empty")
        );
    }

    test("validation rejects future publication year") {
        assert throws(
            () => bookDb.Book.create({
                title: "Future Book",
                isbn: "1234567891",
                publicationYear: 2099,
                pageCount: 100,
                price: 19.99
            }),
            ValidationError("Publication year cannot be in the future")
        );
    }

    test("validation rejects pre-printing-press publication year") {
        assert throws(
            () => bookDb.Book.create({
                title: "Ancient Text",
                isbn: "1234567892",
                publicationYear: 1400,
                pageCount: 50,
                price: 9.99
            }),
            ValidationError("Publication year cannot be before printing press invention")
        );
    }
}

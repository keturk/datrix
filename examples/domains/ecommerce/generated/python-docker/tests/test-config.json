{
  "deploy": {
    "health_check_timeout": 180,
    "max_failures": 10
  },
  "output": {
    "show_output": true,
    "verbosity": 1
  },
  "test": {
    "categories": {
      "exclude": [
        "integration"
      ],
      "include": []
    },
    "coverage": {
      "enabled": false,
      "report_format": "html",
      "threshold": 80
    },
    "max_failures": 10,
    "timeout": 600
  }
}

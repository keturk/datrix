    test("validation rejects empty title") {
        #catalog.Category cat = catalog.Category.create({ name: "SpecCatValTitle" });
        cat.save();
        #catalog.Branch br = catalog.Branch.create({ name: "SpecBranchValTitle", latitude: 40.7128, longitude: -74.0060, country: "US" });
        br.save();
        assert throws(
            () => catalog.Book.create({ title: "", isbn: "1234567890", author: "Author", publicationYear: 2020, categoryId: cat.id, branchId: br.id, price: 9.99, metadata: {}, tags: [] }),
            ValidationError("Title cannot be empty")
        );
    }

    test("validation rejects future publication year") {
        #catalog.Category cat = catalog.Category.create({ name: "SpecCatValYear" });
        cat.save();
        #catalog.Branch br = catalog.Branch.create({ name: "SpecBranchValYear", latitude: 40.7128, longitude: -74.0060, country: "US" });
        br.save();
        assert throws(
            () => catalog.Book.create({ title: "Future Book", isbn: "1234567890", author: "Author", publicationYear: 20999, categoryId: cat.id, branchId: br.id, price: 9.99, metadata: {}, tags: [] }),
            ValidationError("Publication year cannot be in the future")
        );
    }


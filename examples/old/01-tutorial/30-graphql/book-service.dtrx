    test("status change emits BookStatusChanged on update") {
        #catalog.Category cat = catalog.Category.create({ name: "SpecCatStatus" });
        cat.save();
        #catalog.Branch br = catalog.Branch.create({ name: "SpecBranchStatus", latitude: 40.7128, longitude: -74.0060, country: "US" });
        br.save();
        #catalog.Book book = catalog.Book.create({
            title: "Patterns of Enterprise Application Architecture",
            isbn: "9780321127426",
            author: "Martin Fowler",
            publicationYear: 2002,
            categoryId: cat.id,
            branchId: br.id,
            price: 44.99,
            metadata: {},
            tags: []
        });
        book.save();
        book.status = BookStatus.CheckedOut;
        book.save();
        assert emitted(BookStatusChanged(book.id, BookStatus.Available, BookStatus.CheckedOut));
    }

    test("title update does not emit BookStatusChanged") {
        #catalog.Category cat = catalog.Category.create({ name: "SpecCatNoEvent" });
